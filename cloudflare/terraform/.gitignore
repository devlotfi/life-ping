# Terraform state files

*.tfstate
*.tfstate.*

# Terraform lock / cache

.terraform/

# Terraform variable files that may contain secrets

*.tfvars
*.tfvars.json

# Crash logs

crash.log
crash.*.log

# Override files

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files

.terraformrc
terraform.rc

# Environment variable files

.env
.env.*

# Plan output files

*.tfplan
*.plan
